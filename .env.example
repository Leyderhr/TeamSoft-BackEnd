# ===========================================
# TeamSoft Backend - Environment Variables Template
# Copy this file to .env and fill with your values
# ===========================================

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5434/TeamSoft-DB
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_POOL_MAX_SIZE=20
DB_POOL_MIN_IDLE=5

# JWT Security Configuration (Generate a new secret key for production)
# Use: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_key_here_minimum_32_characters
JWT_EXPIRATION_MS=1800000
JWT_REFRESH_EXPIRATION_MS=604800000

# Server Configuration
SERVER_PORT=8081

# Hibernate Configuration
# Options: validate, update, create, create-drop
# IMPORTANT: Use 'validate' in production!
HIBERNATE_DDL_AUTO=validate
HIBERNATE_SHOW_SQL=false
